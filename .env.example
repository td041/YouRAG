# ─────────────────────────────────────────────────────────────────────────────
# YouRAG Environment Configuration
# Copy this file: cp .env.example .env
# NEVER commit .env to git — it contains real secrets
#
# Production (Railway / Fly.io / Render):
#   Set these as environment variables in the dashboard, NOT in .env
#   Railway: Settings → Variables
#   Fly.io:  fly secrets set KEY=value
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here        # https://console.groq.com/keys
LLM_PROVIDER=groq

# ── API Protection (set a strong random string when deploying) ───────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your_secret_key_here
NEXT_PUBLIC_API_KEY=your_secret_key_here   # Must match API_KEY above

# ── Optional LLM Fallbacks ────────────────────────────────────────────────────
# JINA_API_KEY=jina_xxxxx                 # Late Chunking via Jina embeddings-v3
# OPENAI_API_KEY=sk-xxxxx                 # OpenAI fallback (optional)

# ── Vector Database ───────────────────────────────────────────────────────────
# Local (dev): uses embedded Qdrant at QDRANT_DB_PATH
# Production: use Qdrant Cloud → https://cloud.qdrant.io (free 1GB cluster)
QDRANT_DB_PATH=qdrant_db
# QDRANT_SERVER_URL=https://xxxx.aws.cloud.qdrant.io   # Qdrant Cloud URL
# QDRANT_API_KEY=your_qdrant_cloud_api_key

# ── Infrastructure (Docker Compose defaults) ──────────────────────────────────
DATABASE_URL=postgresql://yourag_user:yourag_pass@postgres:5432/yourag_db
REDIS_URL=redis://redis:6379/0

# ── System ────────────────────────────────────────────────────────────────────
DEVICE=cpu          # 'cuda' if GPU available
LOG_LEVEL=INFO
ENVIRONMENT=development   # development | staging | production

# ── Langfuse LLM Tracing (self-hosted on port 3002) ──────────────────────────
# Login: http://localhost:3002  →  admin@gmail.com / admin1234
# Keys below are pre-seeded via LANGFUSE_INIT_* — no manual setup needed
LANGFUSE_PUBLIC_KEY=lf-pk-yourag-local
LANGFUSE_SECRET_KEY=lf-sk-yourag-local
# LANGFUSE_NEXTAUTH_SECRET=change-me-in-production
# LANGFUSE_SALT=change-me-in-production
