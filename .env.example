# cp .env.example .env

GROQ_API_KEY=your_groq_api_key_here

API_KEY=your_secret_key_here        # Bảo vệ endpoint (bỏ comment khi deploy)
NEXT_PUBLIC_API_KEY=your_secret_key_here  # Frontend dùng cùng key
LLM_PROVIDER=groq

GEMINI_API_KEY=AIzaSy_xxxxx       # optional: Production fallback khi Groq rate limit
GEMINI_EVAL_API_KEY=AIzaSy_xxxxx  # optional: Riêng cho RAGAS benchmark (tách khỏi production quota)
JINA_API_KEY=jina_xxxxx           # optional: Late Chunking

QDRANT_DB_PATH=qdrant_db
QDRANT_SERVER_URL=http://qdrant:6333

DATABASE_URL=postgresql://yourag_user:yourag_pass@postgres:5432/yourag_db
REDIS_URL=redis://redis:6379/0

DEVICE=cpu
LOG_LEVEL=INFO

